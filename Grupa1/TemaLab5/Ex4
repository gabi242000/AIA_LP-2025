#include <algorithm>
#include <iostream>
#include <bits/stdc++.h>
#include <vector>
#include <queue>
#include <fstream>
#include <string.h>

using namespace std;


int main()
{
    char a[100];
    cin.get(a, 100);

    int p;
    cin >> p;

    for (int i = 0; i < strlen(a); i++) {
        if (strchr(" ", a[i]) == NULL) {
            for (int j = 0; j < p; j++) {

                if (!(a[i] == 'z' || a[i] == 'Z')) {
                    a[i]++;
                }
                else {
                    a[i] -= 25;
                }
            }
        }
    }

    cout<<a;
    return 0;
}
