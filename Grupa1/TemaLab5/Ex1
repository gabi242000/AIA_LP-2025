#include <algorithm>
#include <iostream>
#include <bits/stdc++.h>
#include <vector>
#include <queue>
#include <fstream>
#include <string.h>

using namespace std;


int main()
{
    char a[100];
    cin.get(a, 100);

    for (int i = 0; i < strlen(a); i++) {
        if (a[i] >= 'a' && a[i] <= 'z') {
            a[i] = a[i] - 32;
        }
    }

    cout<<a;
    return 0;
}
