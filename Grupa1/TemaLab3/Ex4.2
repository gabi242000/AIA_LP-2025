#include <stdio.h>


using namespace std;

int main()
{
    int n, f1 = 0, f2 = 1;

    scanf("%d",&n);

    if(n>=1)
        printf("%d ", f1);
    if(n>=2)
        printf("%d ", f2);

    for(int i=2;i<n;i++) {
        int f3 = f1 + f2;
        f1 = f2;
        f2 = f3;
        printf("%d ", f3);
    }

    return 0;
}
