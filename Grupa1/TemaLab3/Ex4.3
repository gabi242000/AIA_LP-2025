#include <iostream>

using namespace std;

int main()
{
   int n;
   cin>>n;
   int spaces = n-1;

   for(int i=0;i<n;i++) {
       int j = 0;
       while(j<spaces) {
           cout<<" ";
           j++;
       } //nu este for :)))
       for(int k=0;k<1+i*2;k++) {
           cout<<"*";
       }
       spaces--;
       cout<<endl;
   }
}
