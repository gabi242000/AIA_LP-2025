#include <stdio.h>
#include <stdlib.h>

int comp(const void *a, const void *b) {
    return (*(int *)a - *(int *)b);
}

int sortareVector(int v[], int n) {
    qsort(v, n, sizeof(int), comp);
    return v;
}

int cautareBinara(int v[], int n, int x) {
    int a,b, mid;
    a = 0;
    b = n-1;

    while(a<=b) {
        mid = a + (b-a)/2;
        if(v[mid] == x) {
            return 1;
        }
        else if(v[mid] < x) {
            a = mid + 1;
        }
        else if (v[mid] > x) {
            b = mid - 1;
        }
    }

    return 0;
}

int main() {
    int v[100], n, x;
    scanf("%d", &n);
    scanf("%d", &x);
    for (int i = 0; i < n; i++) {
        scanf("%d", &v[i]);
    }
    sortareVector(v, 10);

    if (cautareBinara(v,n,x)) {
        printf("Numarul se afla in vector\n");
    }
    else
        printf("Numarul se afla in vector\n");

    return 0;
}
