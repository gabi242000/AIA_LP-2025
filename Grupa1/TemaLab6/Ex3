#include <stdio.h>
#include <stdlib.h>
#include <string.h>

void cripteaza(char s[], int key) {

    for (int j = 0; j < key; j++)
        for (int i = 0; i < strlen(s); i++) {
            if (s[i] == 'z') {
                s[i] = 'a';
            }
            else
                s[i] += 1;
        }

}

void decripteaza(char s[], int key) {

    for (int j = 0; j < key; j++)
        for (int i = 0; i < strlen(s); i++) {
            if (s[i] == 'a') {
                s[i] = 'z';
            }
            else
                s[i] -= 1;
        }

}

int main() {
    char s[100];
    int key;
    fgets(s, 100, stdin);
    scanf("%d", &key);

    cripteaza(s, key);
    printf("%s\n", s);
    decripteaza(s, key);
    printf("%s\n", s);
    return 0;
}
