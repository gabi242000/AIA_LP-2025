#include <iostream>

using namespace std;

int main()
{
   int n, rand, sum = 0, maxi = 0;

   cin >> n;
   int regele[n][n];

   for (int i = 0; i < n; i++) {
       sum = 0;
       for (int j = 0; j < n; j++) {
           cin >> regele[i][j];
           sum += regele[i][j];
       }
       if (sum > maxi) {
           maxi = sum;
           rand = i;
       }
   }

    cout << endl;
    cout << "Randul cu suma cea mai mare este: " << endl;
    for (int i = 0; i < n; i++) {
        cout<<regele[rand][i]<<" ";
    }
    cout << endl;
    cout << "Iar suma lui este: " << maxi << endl;

    return 0;
}
