#include <algorithm>
#include <iostream>
#include <bits/stdc++.h>
#include <vector>

using namespace std;

int main()
{
   int n, empty = 1;
   cin >> n;
   int v[n][n];
   vector<int> elem;

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
                cin>>v[i][j];
        }
    }
    //ignoram marginile, presupun ca alea nu pot fi elemente varf daca nu au 4 vecini, daca se pun si alea atunci imi pare rau:)
    //in caz ca se pun elementele de pe margini descriu aici pe scurt metoda, intializam matricea de n+1 si cu elementele 0(presupunand ca elementele matricei sunt nr naturale), ca sa nu am erori cand compar
    for (int i = 1; i < n; i++) {
        for (int j = 1; j < n; j++) { 
            if(v[i][j] > v[i+1][j] && v[i][j] > v[i][j+1] && v[i][j] > v[i][j-1] && v[i][j] > v[i-1][j]) {
                elem.push_back(v[i][j]);
                empty = 0;
            }
        }
    }

    if (empty) {
        cout << "Nu exista elemente varf in matrice" << endl;
    }else {
        cout << "Elementele varf sunt: " << endl;
        for (int i = 0; i < elem.size(); i++) {
            cout << elem[i] << " ";
        }
    }
    return 0;
}
