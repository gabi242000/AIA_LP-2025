#include <algorithm>
#include <iostream>
#include <bits/stdc++.h>
#include <vector>

using namespace std;

int main()
{
   int n;
   cin >> n;
   vector<int> v;
    for (int i = 0; i < n; i++) {
        int x;
        cin >> x;
        v.push_back(x);
    }


   sort(v.begin(), v.end());

    for (int i = 0; i < v.size(); i++) {
        if (v[i] == v[i + 1]);
            v.erase(v.begin() + i);
    }

    for (int i = 0; i < v.size(); i++) {
        cout << v[i] << " ";
    }

    return 0;
}
