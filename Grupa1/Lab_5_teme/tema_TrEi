        if (a[0]=='z'&& strlen(a)%2==0) {
            for (int i = 0; i < strlen(a); i++) {
                if (strchr("aeiou", a[i]) != NULL) {
                    if (alternate % 2 != i%2) {
                        frumix=false;
                    }
