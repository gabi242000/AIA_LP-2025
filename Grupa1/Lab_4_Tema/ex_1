#include <stdio.h>

int main() {
    int n;
    scanf("%d",&n);
    int sum=0,sumMax=0,aux;
    int a[n][n];
    for(int i=0;i<n;i++) {
        for(int j=0;j<n;j++) {
            scanf("%d",&a[i][j]);
            sum+=a[i][j];
        }
        if (sum>sumMax) {
            sumMax=sum;
        }
        sum=0;
    }
    printf("%d",sumMax);
}
