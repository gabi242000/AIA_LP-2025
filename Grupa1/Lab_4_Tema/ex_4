#include <stdio.h>
#define n 5

int eVarf(int a[n][n], int i, int j) {
    int poateVarf= a[i][j];
    if (i > 0 && a[i-1][j] >= poateVarf)
        return 0;
    if (i < n-1 && a[i+1][j] >= poateVarf)
        return 0;
    if (j > 0 && a[i][j-1] >= poateVarf)
        return 0;
    if (j < n-1 && a[i][j+1] >= poateVarf)
        return 0;
    return 1;
}

