        for (int j = 0; j < n; j++) {
            scanf("%d", &a[i][j]);
        }
    }
    for (int i=0;i<n;i++) {
        for (int j=0;j<n;j++) {
            if (eVarf(a,i,j)) {
                printf("Element varf la: (%d, %d) cu valoarea %d\n", i, j, a[i][j]);
            }
        }
    }
}
