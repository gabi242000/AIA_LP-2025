#include <stdio.h>

int a[3][3];

int determinant() {
    int det=0;
    for (int i = 0; i < 3; i++) {
        det = det + (a[0][i] * (a[1][(i + 1) % 3] * a[2][(i + 2) % 3] - a[1][(i + 2) % 3] * a[2][(i + 1) % 3]));
        printf("det= %d\n",det);
    }
    return det;
}
void Inversabila(int det){
  printf("Determinantul matricei este %d\n",det);
    if (det == 0) {
        printf("Nu este inversabila \n");
    }else {
        printf("Este inversabila");
    }

}

int main() {
    printf("introdu matricea de 3x3: \n");
    for (int i = 0; i < 3; i++) {
        for (int j = 0; j < 3; j++) {
            scanf("%d", &a[i][j]);
        }
    }
    int det = determinant();
    Inversabila(det);
}
