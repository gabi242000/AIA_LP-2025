#include <stdatomic.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    int n, count = 0;
    int *vector_1, *vector_2;

    scanf("%d", &n);

    vector_1 = (int *)malloc(n * sizeof(int));
    vector_2 = (int *)malloc(n * sizeof(int));
    int sum = 0;
    for (int i = 0; i < n; i++) {
        scanf("%d", &vector_1[i]);
        sum += vector_1[i];
    }

    int media = sum / n;

    for (int i = 0; i < n; i++) {
        if (vector_1[i] > media) {
            vector_2[count] = vector_1[i];
            count++;
            printf("%d ", vector_2[count-1]);
        }
    }


    free(vector_1);
    free(vector_2);
    return 0;
}
