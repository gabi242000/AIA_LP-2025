#include <stdatomic.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>

int main() {
    int n;
    int **vector;

    scanf("%d", &n);

    vector = (int**)malloc(n * sizeof(int*));

    for (int i = 0; i < n; i++) {
        vector[i] = (int *)malloc(n * sizeof(int));
    }

    for (int i = 0; i < n; i++) {
        for (int j = 0; j < n; j++) {
            if (i == j) {
                vector[i][j] = 1;
            }
            else {
                vector[i][j] = 0;
            }

            printf("%d ", vector[i][j]);
        }
        printf("\n");
    }
    return 0;
}
